# Минимальная конфигурация для итерации "сам на себе":
# Telegram + Anthropic + Supabase + Redis. Никакого Paddle/Google/Jira.
# Скопируйте этот файл в .env и заполните значения.

# ---------- Базовый URL приложения ----------
# Локально (для тестов webhook через ngrok/cloudflared) — публичный HTTPS-туннель.
# На VPS — твой домен, например https://aios.example.com
APP_BASE_URL=https://your-domain.example.com

# ---------- Supabase Postgres ----------
# Settings → Database → Connection string (Transaction pooler).
# Формат: postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ---------- Redis ----------
# В docker-compose это redis://redis:6379/0 — менять не нужно.
REDIS_URL=redis://redis:6379/0

# ---------- Telegram ----------
# Токен от @BotFather (он же даст и username бота).
TELEGRAM_BOT_TOKEN=
# Любая случайная строка 32+ символов: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ---------- Anthropic ----------
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Можно оставить дефолты (актуальны на май 2026).
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5-20250929
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ---------- Ключ шифрования OAuth-токенов ----------
# ОБЯЗАТЕЛЕН даже если ты не подключаешь Google/Jira — приложение валидирует длину при старте.
# Сгенерировать: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=

# ---------- Rate limit ----------
RATE_LIMIT_PER_MINUTE=30

# ---------- Опциональное (можно оставить пустым на старте) ----------
# Sentry — добавишь, когда захочешь error tracking.
# SENTRY_DSN=

# Google OAuth (для Work-агента с Google Calendar).
# Добавишь, когда захочешь подключить календарь.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Jira OAuth (для Work-агента с Jira Cloud).
# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=

# Paddle (биллинг). Добавишь на стадии открытия для пользователей.
# PADDLE_WEBHOOK_SECRET=
# PADDLE_PRICE_PERSONAL=
# PADDLE_PRICE_PRO=
# PADDLE_PRICE_BUSINESS=
# PADDLE_PRICE_PKG_S=
# PADDLE_PRICE_PKG_M=
# PADDLE_PRICE_PKG_L=
# CHECKOUT_URL_PERSONAL=
# CHECKOUT_URL_PRO=
# CHECKOUT_URL_BUSINESS=
# CHECKOUT_URL_PKG_S=
# CHECKOUT_URL_PKG_M=
# CHECKOUT_URL_PKG_L=
